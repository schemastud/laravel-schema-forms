{
    "name": "schemastud/laravel-schema-forms",
    "description": "Host-agnostic schema-form primitive: a JSON-Schema-defined form is validated (opis), stored via a swappable FormSubmission model, and optionally notified through a tenant-swappable SubmissionNotifier seam with a record-before-deliver notification outbox (track + replay). Owns the x-swf-notify keyword.",
    "keywords": [
        "laravel",
        "forms",
        "json-schema",
        "submissions",
        "intake",
        "leads",
        "notifications",
        "outbox"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Stephen Rushing",
            "email": "stephen@rushing.dev"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "opis/json-schema": "^2.3",
        "spatie/laravel-data": "^4.0|^5.0",
        "spatie/typescript-transformer": "^3.3",
        "schemastud/laravel-data-schemas": "dev-main"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^2.0|^3.0",
        "laravel/pint": "^1.0",
        "wikimedia/composer-merge-plugin": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "Splicewire\\SchemaForms\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Splicewire\\SchemaForms\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.0.x-dev"
        },
        "laravel": {
            "providers": [
                "Splicewire\\SchemaForms\\SchemaFormsServiceProvider"
            ]
        },
        "merge-plugin": {
            "include": [
                "composer.local.json"
            ]
        }
    },
    "repositories": [
        {
            "type": "git",
            "url": "https://github.com/schemastud/laravel-data-schemas.git"
        },
        {
            "type": "git",
            "url": "https://github.com/stephenr85/laravel-popcorn.git"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "test": "vendor/bin/pest",
        "pint": "@php -d memory_limit=512M vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true,
            "wikimedia/composer-merge-plugin": true
        }
    }
}
