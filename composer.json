{
    "name": "rushing/laravel-form-submissions",
    "description": "Domain-agnostic base leaf for the shared \"a form was submitted\" concept: a swappable FormSubmission model, a RecordsSubmissions action that persists and emits a SubmissionReceived event, and nothing about mail, circuits, or any vertical vocabulary.",
    "keywords": [
        "laravel",
        "forms",
        "submissions",
        "intake",
        "leads"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Stephen Rushing",
            "email": "stephen@rushing.dev"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^2.0|^3.0",
        "laravel/pint": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Rushing\\FormSubmissions\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Rushing\\FormSubmissions\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.0.x-dev"
        },
        "laravel": {
            "providers": [
                "Rushing\\FormSubmissions\\FormSubmissionsServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "test": "vendor/bin/pest",
        "pint": "@php -d memory_limit=512M vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    }
}
